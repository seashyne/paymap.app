{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"],
      "@/features/*": ["./src/features/*"],
      "@/shared/*": ["./src/shared/*"],
      "@/server/*": ["./src/server/*"],
      "@/middleware/*": ["./src/middleware/*"]
    }
  },
  "include": [
    "./seed.ts",
    "./chart-of-accounts.seed.ts",
    "../scripts/**/*.ts"
  ]
}
