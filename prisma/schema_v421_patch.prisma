model Store {
  id             String            @id @default(cuid())
  userId         String
  name           String
  address        String?
  phone          String?
  taxId          String?
  vatRegistered  Boolean           @default(false)
  currency       String            @default("THB")
  logoUrl        String?
  bannerUrl      String?
  themeColor     String?
  backgroundUrl  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  // ... fields เดิม
}
