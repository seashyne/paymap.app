generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountMode {
  personal
  business
  merchant
}

enum InventoryMovement { in
  out
  adjust
  return
}
enum InventoryRef {
  sale
  purchase
  adjustment
  writeoff
}
enum PaymentMethod {
  cash
  qr
  transfer
  card
  credit
}
enum RecurringInterval {
  daily
  weekly
  monthly
  quarterly
  yearly
}

model User {
  plannerEntries       PlannerEntry[]

  id                    String                 @id @default(cuid())
  name                  String
  email                 String
  emailVerified         DateTime?
  passwordHash          String?
  image                 String?
  displayName           String?                // ชื่อที่แสดงแทนชื่อจริง
  username              String?                @unique // @handle สำหรับ profile
  bio                   String?                @db.Text
  phone                 String?
  website               String?
  plan                  Plan                   @default(free)
  role                  Role                   @default(user)
  provider              AuthProvider           @default(credentials)
  accountMode           AccountMode            @default(personal)
  country               String                 @default("TH")
  currency              String                 @default("THB")
  locale                String                 @default("th-TH")
  timezone              String                 @default("Asia/Bangkok")
  uiPreferences         Json?
  stripeCustomerId      String?                @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tosAcceptedAt         DateTime?
  tosVersion            String?
  privacyAcceptedAt     DateTime?
  privacyVersion        String?
  lastLoginAt           DateTime?
  loginCount            Int                    @default(0)
  payProfiles           PayProfile[]           @relation("UserPayProfiles")
  accounts              Account[]
  auditLogs             AuditLog[]
  budgets               Budget[]
  categories            Category[]
  monthlyReports        MonthlyReport[]
  notifications         Notification[]
  organizationMembers   OrganizationMember[]
  ownedFamilies         Family[]                @relation("FamilyOwner")
  familyMembers         FamilyMember[]          @relation("FamilyUser")
  ownedOrganizations    Organization[]
  productSubscriptions  ProductSubscription[]
  journalEntries        JournalEntry[]
  chartOfAccounts       ChartOfAccount[]
  ownedWorkspaces       Workspace[]             @relation("WorkspaceOwner")
  workspaceMemberships  WorkspaceMember[]       @relation("WorkspaceUser")
  recurringTransactions RecurringTransaction[]
  savingsGoals          SavingsGoal[]
  sessions              Session[]
  stores                Store[]
  stripePayments        StripePayment[]
  stripeSubscription    StripeSubscription?
  subscriptions         Subscription[]
  consents              UserConsent[]
  consentLogs           ConsentLog[]
  bankStatements        BankStatement[]
  reconciliationMatches ReconciliationMatch[]
  tokens                Token[]
  transactions          Transaction[]
  wallets               Wallet[]
  walletTransfers       WalletTransfer[]
  installments          Installment[]
  loans                 Loan[]
  assets                Asset[]
  liabilities           Liability[]
  investments           Investment[]
  netWorthSnapshots     NetWorthSnapshot[]
  userStats             UserStats?
  achievements          Achievement[]

  // v3.1: 1 email can register in multiple modes — email+mode pair must be unique
  @@unique([email, accountMode])
  @@index([email])
  @@index([role])
  @@index([stripeCustomerId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expires])  // v1.9: fast cleanup of expired sessions
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Token {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @default(cuid())
  type      TokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, type])
  @@index([expiresAt])  // v1.9: cleanup expired tokens
  @@map("tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model StripeSubscription {
  id                   String          @id @default(cuid())
  userId               String          @unique
  stripeSubscriptionId String          @unique
  stripePriceId        String
  stripeProductId      String
  plan                 Plan
  status               StripeSubStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean         @default(false)
  canceledAt           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
  @@map("stripe_subscriptions")
}

model StripePayment {
  id              String   @id @default(cuid())
  userId          String
  stripeInvoiceId String   @unique
  amountPaid      Int
  currency        String
  status          String
  plan            Plan
  periodStart     DateTime
  periodEnd       DateTime
  invoiceUrl      String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("stripe_payments")
}

model Category {
  id            String         @id @default(cuid())
  userId        String
  name          String
  type          CategoryType
  color         String?
  icon          String?
  isSystem      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  budgets       Budget[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryRules CategoryRule[]
  transactions  Transaction[]

  @@unique([userId, name, type])
  @@index([userId, type])
  @@map("categories")
}

model Transaction {
  id         String          @id @default(cuid())
  userId     String
  categoryId String?
  type       TransactionType
  amount     Decimal         @db.Decimal(12, 2)
  currency   String          @default("THB")
  amountUsd  Decimal?        @db.Decimal(12, 4)
  note       String?
  receiptUrl String?   // Cloudflare R2 URL for receipt image/PDF
  happenedAt DateTime
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  category   Category?       @relation(fields: [categoryId], references: [id])
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reconciliationMatches ReconciliationMatch[]

  @@index([userId, happenedAt])
  @@index([userId, deletedAt, happenedAt])
  @@index([userId, type])
  @@index([userId, deletedAt, type, happenedAt])
  @@index([userId, categoryId, happenedAt])
  @@index([userId, currency])
  @@map("transactions")
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String
  month       Int
  year        Int
  limitAmount Decimal  @db.Decimal(12, 2)
  currency    String   @default("THB")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@index([userId, year, month])
  @@map("budgets")
}

model SavingsGoal {
  id           String           @id @default(cuid())
  userId       String
  name         String
  targetAmount Decimal          @db.Decimal(12, 2)
  savedAmount  Decimal          @default(0) @db.Decimal(12, 2)
  currency     String           @default("THB")
  icon         String?          @default("🎯")
  color        String?          @default("#f59e0b")
  deadline     DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deposits     SavingsDeposit[]
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("savings_goals")
}

model SavingsDeposit {
  id        String      @id @default(cuid())
  goalId    String
  amount    Decimal     @db.Decimal(12, 2)
  note      String?
  createdAt DateTime    @default(now())
  goal      SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("savings_deposits")
}

model Subscription {
  id                  String       @id @default(cuid())
  userId              String
  name                String
  amount              Decimal      @db.Decimal(10, 2)
  currency            String       @default("THB")
  billingCycle        BillingCycle @default(monthly)
  nextBillingAt       DateTime
  renewalNotifiedAt   DateTime?
  logo                String?
  color               String?
  note                String?
  planCode            String?
  startedAt           DateTime     @default(now())
  cancelAtPeriodEnd   Boolean      @default(false)
  cancelledAt         DateTime?
  endedAt             DateTime?
  status              SubStatus    @default(active)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, status, nextBillingAt])
  @@index([userId, nextBillingAt])
  @@map("subscriptions")
}

model Organization {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  ownerId      String
  baseCurrency String               @default("THB")
  country      String               @default("TH")
  plan         Plan                 @default(free)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  approvals    ApprovalRequest[]
  branches     Branch[]
  warehouses   Warehouse[]
  products     Product[]
  customers    Customer[]
  employees    Employee[]
  invoices     Invoice[]
  bankStatements BankStatement[]
  reports      MonthlyReport[]
  members      OrganizationMember[]
  owner        User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  payrollRuns  PayrollRun[]
  quotations   Quotation[]
  workspace    Workspace?
  teams        Team[]
  webhooks     WebhookEndpoint[]

  @@index([ownerId])
  @@map("organizations")
}

model Warehouse {
  id             String             @id @default(cuid())
  organizationId String
  code           String?
  name           String
  address        String?
  note           String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  balances       InventoryBalance[]
  movements      InventoryMovementLog[]

  @@unique([organizationId, code])
  @@index([organizationId, deletedAt, name])
  @@map("warehouses")
}

model Product {
  id               String                @id @default(cuid())
  organizationId   String
  sku              String?
  name             String
  description      String?
  category         String?
  unit             String?               @default("ชิ้น")
  barcode          String?
  costPrice        Decimal               @default(0) @db.Decimal(12, 2)
  salePrice        Decimal               @default(0) @db.Decimal(12, 2)
  vatRate          Decimal               @default(7) @db.Decimal(5, 2)
  reorderPoint     Int                   @default(0)
  currency         String                @default("THB")
  status           ProductStatus         @default(active)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  deletedAt        DateTime?
  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  balances         InventoryBalance[]
  movements        InventoryMovementLog[]

  @@unique([organizationId, sku])
  @@index([organizationId, deletedAt, name])
  @@index([organizationId, status, reorderPoint])
  @@map("products")
}

model InventoryBalance {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  qtyOnHand   Int       @default(0)
  avgCost     Decimal   @default(0) @db.Decimal(12, 2)
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([warehouseId, qtyOnHand])
  @@map("inventory_balances")
}

model InventoryMovementLog {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  movement    InventoryMovement
  refType     InventoryRef?
  refId       String?
  qty         Int
  qtyBefore   Int
  qtyAfter    Int
  unitCost    Decimal?          @db.Decimal(12, 2)
  note        String?
  movedAt     DateTime          @default(now())
  createdAt   DateTime          @default(now())
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([productId, movedAt])
  @@index([warehouseId, movedAt])
  @@map("inventory_movement_logs")
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  customerCode   String?
  name           String
  contactName    String?
  email          String?
  phone          String?
  taxId          String?
  branchName     String?
  branchCode     String?
  address        String?
  paymentTerms   Int?         @default(30)
  currency       String       @default("THB")
  note           String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  quotations     Quotation[]
  invoices       Invoice[]

  @@unique([organizationId, customerCode])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt, name])
  @@map("customers")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole      @default(member)
  title          String?
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  code           String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("teams")
}

model Branch {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  code           String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@map("branches")
}

model QuoteItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Decimal   @db.Decimal(12, 2)
  unitPrice   Decimal   @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model Quotation {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String?
  number         String
  customerName   String
  customerEmail  String?
  status         QuoteStatus  @default(draft)
  subtotal       Decimal      @db.Decimal(12, 2)
  taxAmount      Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal      @db.Decimal(12, 2)
  validUntil     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          QuoteItem[]

  @@unique([organizationId, number])
  @@index([customerId])
  @@map("quotations")
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String?
  number         String
  customerName   String
  customerEmail  String?
  status         InvoiceStatus @default(draft)
  currency       String        @default("THB")
  subtotal       Decimal       @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  note           String?
  issuedAt       DateTime?
  dueDate        DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          InvoiceItem[]
  payments       InvoicePayment[]

  deletedAt      DateTime?   // v1.9: compliance — invoice numbers never disappear
  @@unique([organizationId, number])
  @@index([organizationId, deletedAt])
  @@index([customerId])
  @@map("invoices")
}


model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePayment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Decimal  @db.Decimal(12, 2)
  method      String
  reference   String?
  note        String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paidAt])
  @@map("invoice_payments")
}

model BankStatement {
  id             String             @id @default(cuid())
  userId         String
  organizationId String?
  source         String
  sourceLabel    String?
  currency       String             @default("THB")
  accountName    String?
  accountNumber  String?
  importedAt     DateTime           @default(now())
  createdAt      DateTime           @default(now())
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  lines          StatementLine[]

  @@index([userId, importedAt])
  @@index([organizationId])
  @@map("bank_statements")
}

model StatementLine {
  id           String               @id @default(cuid())
  statementId  String
  lineNo       Int
  bookedAt     DateTime
  description  String
  reference    String?
  amount       Decimal              @db.Decimal(12, 2)
  kind         TransactionType
  createdAt    DateTime             @default(now())
  statement    BankStatement        @relation(fields: [statementId], references: [id], onDelete: Cascade)
  matches      ReconciliationMatch[]

  @@index([statementId, lineNo])
  @@index([bookedAt])
  @@map("statement_lines")
}

model ReconciliationMatch {
  id              String          @id @default(cuid())
  userId          String
  statementLineId String
  transactionId   String
  status          String          @default("matched")
  confidence      Float           @default(0.9)
  deltaAmount     Decimal         @default(0) @db.Decimal(12, 2)
  deltaDays       Int             @default(0)
  approvedAt      DateTime?
  approvedById    String?
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  statementLine   StatementLine   @relation(fields: [statementLineId], references: [id], onDelete: Cascade)
  transaction     Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([statementLineId, transactionId])
  @@index([userId, status])
  @@map("reconciliation_matches")
}

model ConsentVersion {
  id          String      @id @default(cuid())
  key         String
  version     String
  label       String
  effectiveAt DateTime
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  consents    UserConsent[]

  @@unique([key, version])
  @@index([key, isActive])
  @@map("consent_versions")
}

model UserConsent {
  id               String          @id @default(cuid())
  userId           String
  consentKey       String
  versionId        String
  status           String          @default("accepted")
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  version          ConsentVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([userId, consentKey, versionId])
  @@index([userId, consentKey])
  @@map("user_consents")
}

model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  consentKey  String
  action      String
  version     String
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentKey])
  @@index([createdAt])
  @@map("consent_logs")
}

model ApprovalRequest {
  id             String         @id @default(cuid())
  organizationId String
  requestedById  String
  type           ApprovalType
  status         ApprovalStatus @default(pending)
  title          String
  amount         Decimal?       @db.Decimal(12, 2)
  payload        Json?
  approvedById   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("approval_requests")
}

model RecurringTransaction {
  id           String    @id @default(cuid())
  userId       String
  merchant     String
  amount       Decimal   @db.Decimal(12, 2)
  interval     String
  confidence   Int       @default(80)
  nextExpected DateTime?
  lastDetected DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, merchant])
  @@map("recurring_transactions")
}

model CategoryRule {
  id         String   @id @default(cuid())
  keyword    String
  categoryId String
  confidence Int      @default(85)
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([keyword])
  @@map("category_rules")
}

model MonthlyReport {
  id             String           @id @default(cuid())
  userId         String?
  organizationId String?
  month          Int
  year           Int
  type           NotificationType @default(monthly_report)
  summary        Json
  deliveredAt    DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id])

  @@index([userId, year, month])
  @@index([organizationId, year, month])
  @@map("monthly_reports")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt  DateTime?       // v1.9: TTL — auto-expire after 90 days
  updatedAt  DateTime         @updatedAt
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
  @@index([expiresAt])          // cleanup job
  @@map("notifications")
}

model WebhookEndpoint {
  id             String       @id @default(cuid())
  organizationId String
  url            String
  secret         String
