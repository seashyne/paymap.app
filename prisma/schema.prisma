// ─── Pay Profile ─────────────────────────────────────────────────────────────
// หน้ารับเงินสาธารณะ — 1 Workspace มีได้ 1 PayProfile
// ไม่มีค่าธรรมเนียม ตรวจสอบได้ — เพียงแสดง QR/PromptPay ให้ผู้จ่ายใช้

model PayProfile {
  id            String          @id @default(cuid())
  // Workspace link (ต้องเลือกอย่างใดอย่างหนึ่ง)
  userId        String          // owner
  workspaceType PayProfileMode  // personal | business | merchant
  // อาจ link กับ org หรือ store ถ้าเป็น business/merchant
  organizationId String?
  storeId        String?

  // Public slug: paymap.app/pay/{slug}
  slug          String          @unique
  isActive      Boolean         @default(true)

  // Display info
  displayName   String          // ชื่อที่แสดงบนหน้า Pay
  bio           String?         // คำอธิบายสั้น
  avatarUrl     String?

  // ── Free tier ──
  coverColor    String?         @default("#7c3aed")

  // ── Premium customization (plan >= pro/starter) ──
  coverImageUrl String?         // URL รูปภาพพื้นหลัง
  coverStyle    String?         @default("color")  // "color" | "image" | "gradient" | "pattern"
  coverGradient String?         // เช่น "135deg,#7c3aed,#0ea5e9"
  coverPattern  String?         // "dots" | "grid" | "waves" | "noise" | "circuit"

  frameStyle    String?         @default("rounded") // "rounded" | "circle" | "hexagon" | "ring" | "glow" | "badge"
  frameColor    String?         // สีกรอบรูป
  frameGradient String?         // gradient กรอบ เช่น "gold" | "rainbow" | "custom"

  // Typography & layout
  fontStyle     String?         @default("default") // "default" | "serif" | "mono" | "bold" | "elegant"
  layoutStyle   String?         @default("center")  // "center" | "left" | "card" | "minimal" | "magazine"
  badgeText     String?         // ข้อความ badge เล็กๆ เช่น "Verified" "Open for work"
  badgeColor    String?         // สี badge

  // Payment channels (เก็บ encrypted หรือ public info เท่านั้น)
  promptpayId   String?         // เบอร์โทร หรือ เลขประจำตัวประชาชน / Tax ID
  promptpayType PromptPayType?  // PHONE | NID | TAX
  bankAccount   String?         // เลขบัญชีธนาคาร (optional display)
  bankName      String?         // ชื่อธนาคาร

  // Optional: preset amounts
  presetAmounts Int[]           // เช่น [50, 100, 500, 1000]
  currency      String          @default("THB")
  allowCustom   Boolean         @default(true) // ให้ผู้จ่ายใส่จำนวนเองได้

  // Optional: message/note request
  requestNote   Boolean         @default(false) // ขอให้ผู้จ่ายระบุเหตุผล

  // Stats
  totalReceived Int             @default(0) // จำนวนครั้งที่มีคนกด (ไม่ใช่ยอดเงิน เพราะ promptpay ไม่มี webhook)
  lastViewedAt  DateTime?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation("UserPayProfiles", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceType])
  @@index([slug])
  @@map("pay_profiles")
}

enum PayProfileMode {
  personal
  business
  merchant
}

enum PromptPayType {
  PHONE
  NID
  TAX
}

enum MerchantPlan {
  starter
  growth
