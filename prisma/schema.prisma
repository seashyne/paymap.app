// ── 1. Multi-Wallet ──────────────────────────────────────────────
model Wallet {
  id           String       @id @default(cuid())
  userId       String
  name         String
  type         WalletType
  balance      Decimal      @default(0) @db.Decimal(12, 2)
  currency     String       @default("THB")
  color        String?      @default("#8b5cf6")
  icon         String?      @default("💳")
  bankName     String?
  accountLast4 String?
  isDefault    Boolean      @default(false)
  isArchived   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transfers    WalletTransfer[] @relation("WalletFrom")
  transfersTo  WalletTransfer[] @relation("WalletTo")

  @@index([userId])
  @@map("wallets")
}

model WalletTransfer {
  id           String   @id @default(cuid())
  userId       String
  fromWalletId String
  toWalletId   String
  amount       Decimal  @db.Decimal(12, 2)
  fee          Decimal  @default(0) @db.Decimal(10, 2)
  note         String?
  happenedAt   DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromWallet   Wallet   @relation("WalletFrom", fields: [fromWalletId], references: [id])
  toWallet     Wallet   @relation("WalletTo", fields: [toWalletId], references: [id])

  @@index([userId])
  @@index([fromWalletId])
  @@index([toWalletId])
  @@map("wallet_transfers")
}

// ── 2. Installment System ─────────────────────────────────────────
model Installment {
  id              String              @id @default(cuid())
  userId          String
  name            String
  totalAmount     Decimal             @db.Decimal(12, 2)
  downPayment     Decimal             @default(0) @db.Decimal(12, 2)
  monthlyAmount   Decimal             @db.Decimal(12, 2)
  totalMonths     Int
  paidMonths      Int                 @default(0)
  interestRate    Decimal             @default(0) @db.Decimal(5, 2)
  currency        String              @default("THB")
  startDate       DateTime
  nextDueDate     DateTime
  icon            String?             @default("📱")
  color           String?             @default("#f59e0b")
  note            String?
  status          InstallmentStatus   @default(active)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments        InstallmentPayment[]

  @@index([userId])
  @@index([userId, status])
  @@map("installments")
}

model InstallmentPayment {
  id             String      @id @default(cuid())
  installmentId  String
  amount         Decimal     @db.Decimal(12, 2)
  paidAt         DateTime
  note           String?
  createdAt      DateTime    @default(now())
  installment    Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@index([installmentId])
  @@map("installment_payments")
}

// ── 3. Loan Tracking ─────────────────────────────────────────────
model Loan {
  id           String     @id @default(cuid())
  userId       String
  personName   String
  direction    LoanDirection
  amount       Decimal    @db.Decimal(12, 2)
  remaining    Decimal    @db.Decimal(12, 2)
  currency     String     @default("THB")
  dueDate      DateTime?
  note         String?
  status       LoanStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repayments   LoanRepayment[]

  @@index([userId])
  @@index([userId, status])
  @@map("loans")
}

model LoanRepayment {
  id        String   @id @default(cuid())
  loanId    String
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime
  note      String?
  createdAt DateTime @default(now())
  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_repayments")
}

// ── 4. Net Worth System ───────────────────────────────────────────
model Asset {
  id          String    @id @default(cuid())
  userId      String
  name        String
  type        AssetType
  value       Decimal   @db.Decimal(14, 2)
  currency    String    @default("THB")
  icon        String?   @default("🏠")
  color       String?   @default("#22c55e")
  note        String?
  asOfDate    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, asOfDate])
  @@map("assets")
}

model Liability {
  id          String        @id @default(cuid())
  userId      String
  name        String
  type        LiabilityType
  amount      Decimal       @db.Decimal(14, 2)
  currency    String        @default("THB")
  icon        String?       @default("💳")
  color       String?       @default("#ef4444")
  note        String?
  asOfDate    DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, asOfDate])
  @@map("liabilities")
}

model NetWorthSnapshot {
  id          String   @id @default(cuid())
  userId      String
  totalAssets Decimal  @db.Decimal(14, 2)
  totalDebt   Decimal  @db.Decimal(14, 2)
  netWorth    Decimal  @db.Decimal(14, 2)
  snapshotAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, snapshotAt])
  @@map("net_worth_snapshots")
}

// ── 5. Investment Tracker ─────────────────────────────────────────
model Investment {
  id           String           @id @default(cuid())
  userId       String
  name         String
  ticker       String?
  type         InvestmentType
  units        Decimal          @db.Decimal(14, 6)
  avgCost      Decimal          @db.Decimal(14, 4)
  currentPrice Decimal          @db.Decimal(14, 4)
  currency     String           @default("THB")
  exchange     String?
  icon         String?          @default("📈")
  color        String?          @default("#14b8a6")
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions InvestmentTx[]

  @@index([userId])
  @@map("investments")
}

model InvestmentTx {
  id           String          @id @default(cuid())
  investmentId String
  txType       InvestmentTxType
  units        Decimal         @db.Decimal(14, 6)
  price        Decimal         @db.Decimal(14, 4)
  fee          Decimal         @default(0) @db.Decimal(10, 2)
  happenedAt   DateTime
  note         String?
  createdAt    DateTime        @default(now())
  investment   Investment      @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId])
  @@map("investment_txs")
}

// ── 6. Gamification ───────────────────────────────────────────────
model UserStats {
  id              String   @id @default(cuid())
  userId          String   @unique
  xp              Int      @default(0)
  level           Int      @default(1)
  savingStreak    Int      @default(0)
  lastSavingDate  DateTime?
  budgetStreak    Int      @default(0)
  lastBudgetDate  DateTime?
  totalBadges     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  code        String
  title       String
  description String
  icon        String   @default("🏆")
  xpReward    Int      @default(10)
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
  @@map("achievements")
}

// ── New Enums ─────────────────────────────────────────────────────
enum WalletType {
  cash
  bank
  credit_card
  ewallet
  crypto
}

enum InstallmentStatus {
  active
  completed
  cancelled
}

enum LoanDirection {
  lent
  borrowed
}

enum LoanStatus {
  active
  settled
  overdue
}

enum AssetType {
  cash
  stock
  crypto
  property
  vehicle
  fund
  other
}

enum LiabilityType {
  credit_card
  mortgage
  car_loan
  personal_loan
  other
}

enum InvestmentType {
  stock
  fund
  crypto
  etf
  bond
  other
}

enum InvestmentTxType {
  buy
  sell
  dividend
}

// ── v5 Accounting Engine ───────────────────────────────────────────────────

model ChartOfAccount {
  id      String  @id @default(cuid())
  userId  String
  code    String
  name    String
  nameTH  String?
  type    AccountType
  isSystem Boolean @default(false)
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lines   LedgerLine[]

  @@unique([userId, code])
  @@index([userId, type])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id          String    @id @default(cuid())
  userId      String
  orgId       String?
  description String?
  date        DateTime  @default(now())
  sourceType  String?   // "transaction" | "payroll" | "invoice" | "manual"
  sourceId    String?
  createdAt   DateTime  @default(now())

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lines  LedgerLine[]

  @@index([userId, date])
  @@index([userId, sourceType, sourceId])
  @@map("journal_entries")
}

model LedgerLine {
  id        String  @id @default(cuid())
  journalId String
  accountId String
  debit     Float   @default(0)
  credit    Float   @default(0)
  note      String?

  journal JournalEntry   @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([journalId])
  @@index([accountId])
  @@map("ledger_lines")
}

enum AccountType {
  asset
  liability
  equity
  revenue
  expense
}


model PlanFeature {
  id        String   @id @default(cuid())
  product   String
  planCode  String
  feature   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([product, planCode, feature])
  @@index([product, planCode])
  @@map("plan_features")
}


enum PlannerEntryKind {
  note
  task
  reminder
}

enum PlannerEntryStatus {
  open
  done
  archived
}

model PlannerEntry {
  id          String             @id @default(cuid())
  userId      String
  workspace   AccountMode        @default(personal)
  kind        PlannerEntryKind   @default(note)
  status      PlannerEntryStatus @default(open)
  title       String
  content     String?            @db.Text
  dueAt       DateTime?
  priority    Int                @default(2)
  relatedPath String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workspace, status])
  @@index([dueAt])
  @@map("planner_entries")
}
