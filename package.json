{
  "name": "paymap",
  "version": "15.3.1",
  "description": "PayMap works on web, but is best as a Windows app where your data stays with you.",
  "author": "Seashyne",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "desktop:dev": "electron electron/main.cjs --dev",
    "desktop:pack:win": "bun run build && electron-builder --win nsis",
    "desktop:dir:win": "bun run build && electron-builder --win dir",
    "desktop:portable:win": "bun run build && node scripts/package-windows-portable.cjs",
    "release:windows": "bun run desktop:portable:win",
    "postinstall": "prisma generate",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node -P prisma/tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && bun run db:seed",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "typecheck": "tsc --noEmit",
    "verify-env": "ts-node --transpile-only scripts/verify-env.ts",
    "smoke": "ts-node --transpile-only scripts/smoke-test.ts",
    "arch:report": "ts-node --transpile-only scripts/architecture-report.ts",
    "jobs:worker": "ts-node -r tsconfig-paths/register --transpile-only src/server/jobs/worker-runner.ts",
    "repo:validate": "ts-node -P prisma/tsconfig.seed.json --transpile-only scripts/repo-validate.ts",
    "arch:v14:validate": "ts-node -P prisma/tsconfig.seed.json --transpile-only scripts/repo-validate.ts --v14"
  },
  "build": {
    "appId": "app.paymap.desktop",
    "productName": "PayMap",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "prisma/**/*",
      "next.config.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PayMap-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PayMap"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@hookform/resolvers": "^3.9.0",
    "@neondatabase/serverless": "^0.9.4",
    "ws": "^8.18.0",
    "@prisma/adapter-neon": "^5.17.0",
    "@prisma/client": "^5.17.0",
    "@sentry/nextjs": "^8.33.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.56.0",
    "clsx": "^2.1.1",
    "firebase": "^11",
    "firebase-admin": "^12.3.0",
    "ioredis": "^5.10.0",
    "jose": "^5.6.3",
    "lucide-react": "^0.263.1",
    "next": "14.1.4",
    "next-auth": "^4.24.7",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.52.1",
    "resend": "^3.4.0",
    "stripe": "^16.0.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.0.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8",
    "eslint-config-next": "14.1.4",
    "postcss": "^8",
    "prisma": "^5.17.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
